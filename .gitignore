# Extracted files (regenerated from raw sources)
raw/.extracted/

# Binary source files (avoid bloating git history)
raw/*.pdf
raw/*.epub
raw/*.docx
raw/*.xlsx
raw/*.xls
raw/*.pptx

# Dependencies
node_modules/
__pycache__/
*.pyc

# IDE
.idea/

# OS
.DS_Store

# Local Claude settings (permissions, not shared)
.claude/settings.local.json

# Local design docs
docs/
